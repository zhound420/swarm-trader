# AI Hedge Fund — Environment Variables
# Copy this to .env and fill in your keys.
# .env is gitignored and will NOT be committed.

# Alpaca Paper Trading (required for trade execution)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Financial data (DEPRECATED — no longer required)
# api.py now uses free sources: yfinance + SEC EDGAR XBRL.
# The old financialdatasets.ai implementation is backed up as api_original.py.
# To revert: copy src/tools/api_original.py to src/tools/api.py
# FINANCIAL_DATASETS_API_KEY=

# SEC EDGAR requires a User-Agent header (name + email). Optional override:
# SEC_USER_AGENT=YourApp admin@example.com

# LLM providers (only needed if NOT using Ollama)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
